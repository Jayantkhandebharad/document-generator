# Azure OpenAI (use these for Azure)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# This is the model used for every request. Set to your deployment name in Azure Portal (e.g. gpt-4o, gpt-4o-mini).
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Or standard OpenAI (if not using Azure)
# OPENAI_API_KEY=sk-...

# Optional: model for non-Azure only. For Azure, the app uses AZURE_OPENAI_DEPLOYMENT above.
# FORMATTER_LLM_MODEL=gpt-4o-mini

# Optional: max output tokens (default 65536). Increase to 131072 for very long documents if output is truncated.
FORMATTER_LLM_MAX_TOKENS=16384 
# Optional: when raw text exceeds this many characters, use a compact prompt so full input fits (default 28000).
# FORMATTER_LLM_LONG_TEXT_CHARS=28000